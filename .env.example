# =========================================================================
# EcoSphere AI — Environment Variables Template
# Copy this file to `.env` and configure with your keys for local development
# =========================================================================

# ---- Application Config ----
# Local dev port configuration
PORT=5173
VITE_APP_NAME="EcoSphere AI"

# ---- API Integration (Optional) ----
# Swap the client-side mock AI coach engine with a live Gemini or OpenAI API service
# VITE_GEMINI_API_KEY=your_gemini_api_key_here
# VITE_AI_MODEL=gemini-2.5-flash

# ---- Map Services (Optional) ----
# Map tile provider credentials if upgrading leaflet maps to Mapbox/Stadia Maps
# VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# ---- Server Backend (Optional) ----
# Swap client-side mock memory data logs with a live REST or GraphQL backend
VITE_API_BASE_URL=http://localhost:8000/api/v1
